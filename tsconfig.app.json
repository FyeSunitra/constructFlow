// tsconfig.app.json - ลอง remove "types" ออก หรือเพิ่ม vue
{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    // ลบ "types": ["vite/client"] ออก 
    // เพราะ @vue/tsconfig จัดการให้แล้ว
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "src/**/*.d.ts"]
}